---
const prompts = [
  { title: 'System design', icon: 'cube', text: 'Design a scalable URL shortener with caching, rate limiting, and analytics.' },
  { title: 'Product launch', icon: 'rocket', text: 'Plan a 6-week product launch with milestones, owners, and dependencies.' },
  { title: 'User journey', icon: 'route', text: "Map a user's first-week journey from signup to first 'aha' moment." },
  { title: 'Decision tree', icon: 'branch', text: 'Should I rent or buy? Walk through the trade-offs as a decision tree.' },
  { title: 'Trip plan', icon: 'compass', text: 'Plan a 5-day Lisbon trip with daily themes, must-see spots, and food stops.' },
  { title: 'Family tree', icon: 'people', text: 'Sketch a small family tree across three generations with key relationships.' }
];

const workflow = [
  ['Prompt', 'Describe rough notes, tickets, or pasted architecture context.'],
  ['Mermaid', 'Keep diagrams inspectable, portable, and easy to review.'],
  ['Repair', 'Fix syntax, layout, labels, and missing edges without starting over.'],
  ['Export', 'Ship SVG, PNG, and Mermaid source into docs, PRs, or issues.']
];

const features = [
  {
    track: 'Always editable',
    title: 'A diagram workspace that stays close to the source.',
    text: 'Graphini keeps chat, Mermaid, rendered canvas, and document notes together so a system sketch can become handoff material without changing tools.',
    points: ['Canvas, code, document, and chat in one workspace', 'Readable Mermaid that can be copied or versioned']
  },
  {
    track: 'Syntax aware',
    title: 'Repair broken diagrams without flattening intent.',
    text: 'When Mermaid gets noisy, the assistant can correct syntax and improve structure while preserving the architecture you already described.',
    points: ['Error-aware fixes for Mermaid output', 'Flowcharts, sequence diagrams, ERDs, timelines, and C4-style maps']
  },
  {
    track: 'Ready to ship',
    title: 'Export the work into the places decisions happen.',
    text: 'Send clean assets into project docs, pull requests, architecture reviews, incident reports, and planning notes.',
    points: ['SVG, PNG, and source export', 'Useful for architecture, API, data, and incident documentation']
  }
];

const essentials = [
  {
    title: 'Mermaid-native rendering',
    text: 'Diagrams render straight from Mermaid source so the canvas always matches the code beside it.'
  },
  {
    title: 'Syntax-aware repair',
    text: 'When the parser breaks, the assistant patches the diagram without flattening the structure you described.'
  },
  {
    title: 'Live canvas preview',
    text: 'Pan, zoom, and inspect the diagram while it updates as the conversation moves.'
  },
  {
    title: 'Portable export',
    text: 'Ship SVG, PNG, and Mermaid source into docs, PRs, and review tools without a re-render step.'
  },
  {
    title: 'Prompt to handoff',
    text: 'Take a rough note from a ticket and leave with an artifact a teammate can read on their own.'
  }
];

const whyChoose = [
  ['Context-fresh', 'Capture system thinking the moment it lands, before the diagram drifts from the conversation.'],
  ['Plain Mermaid', 'Diagrams stay as plain text — diff-friendly, copy-friendly, version-friendly.'],
  ['Repair-first', 'Broken syntax and odd layouts get corrected without losing the structure you described.'],
  ['Multi-format', 'Sequence flows, flowcharts, ERDs, C4 maps, and incident timelines from one prompt surface.'],
  ['Portable export', 'SVG, PNG, and source ship into docs, PRs, and review tools without re-rendering.'],
  ['Stays inspectable', 'Code, canvas, and chat sit side-by-side so the diagram is never a black box.']
];

const stats = [
  ['5', 'diagram formats tuned for technical teams'],
  ['4', 'workspace surfaces connected by context'],
  ['0', 'lock-in: Mermaid stays plain text'],
  ['1', 'place to prompt, edit, repair, and export']
];

const integrations = [
  'Mermaid',
  'Markdown',
  'GitHub',
  'OpenRouter',
  'OpenAI',
  'Gemini',
  'SVG',
  'PNG',
  'Docs'
];

const faqs = [
  ['Is the output editable?', 'Yes. Graphini keeps Mermaid source visible, so diagrams can be edited, copied, reviewed, and versioned.'],
  ['Can it fix Mermaid errors?', 'Yes. The workspace has a syntax-aware repair loop for broken diagrams and layout issues.'],
  ['Is this only for architecture diagrams?', 'No. It is useful for system maps, sequence flows, incident timelines, ERDs, and documentation diagrams.']
];

const encodedPrompt = (prompt: string) => `/app?prompt=${encodeURIComponent(prompt)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Graphini — a cowork for visual thinking</title>
    <meta
      name="description"
      content="Graphini is an AI cowork for visual thinking — diagrams, Mermaid, and Markdown that take shape as you talk through ideas. Fast iteration, editable source, portable export."
    />
    <meta name="keywords" content="AI cowork, visual thinking, AI diagram tool, Mermaid editor, Markdown editor, flowchart AI, sequence diagram AI, ER diagram, system diagram, technical documentation" />
    <meta property="og:title" content="Graphini — a cowork for visual thinking" />
    <meta
      property="og:description"
      content="An AI cowork where diagrams, Mermaid, and Markdown take shape as you think. Built for the messy middle of technical work."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://graphini.magnova.ai" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href="https://graphini.magnova.ai" />
    <link rel="icon" type="image/x-icon" href="/favicons/favicon.ico" />
    <link
      rel="preload"
      href="/fonts/Inter-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/JetBrainsMono-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <!-- Icon sprite — reused by prompt pills. Stays at 0×0, no visual footprint. -->
    <svg aria-hidden="true" focusable="false" style="position:absolute;width:0;height:0;overflow:hidden" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <symbol id="i-cube" viewBox="0 0 24 24">
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3zM4 7.5L12 12l8-4.5M12 12v9"/>
        </symbol>
        <symbol id="i-rocket" viewBox="0 0 24 24">
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M14 4c4 0 6 2 6 6 0 3-3 6-6 8l-3 1-3-3 1-3c2-3 5-6 8-6 0 0-1 3-3 5M7 14c-2 1-3 4-3 6 2 0 5-1 6-3M9 12l3 3"/>
        </symbol>
        <symbol id="i-route" viewBox="0 0 24 24">
          <circle cx="6" cy="6" r="2.5" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="18" cy="18" r="2.5" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M6 8.5v3a4 4 0 004 4h4a4 4 0 014 4"/>
        </symbol>
        <symbol id="i-branch" viewBox="0 0 24 24">
          <circle cx="6" cy="5" r="2" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="18" cy="5" r="2" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="12" cy="19" r="2" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" d="M7 7l4 10M17 7l-4 10"/>
        </symbol>
        <symbol id="i-compass" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M15 9l-2 5-5 2 2-5 5-2z"/>
        </symbol>
        <symbol id="i-people" viewBox="0 0 24 24">
          <circle cx="9" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="17" cy="9" r="2.5" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M3 19c0-3 3-5 6-5s6 2 6 5M14 19c0-2 2-4 4-4s4 1.5 4 4"/>
        </symbol>
      </defs>
    </svg>

    <div class="page-shell">
      <header class="site-header">
        <div class="header-inner">
          <a class="brand" href="/" aria-label="Graphini home">
            <img src="/brand/logo.png" alt="" />
            <span>Graphini</span>
          </a>
          <nav class="nav-pill" aria-label="Primary navigation">
            <a href="#features">Features</a>
            <a href="#workflow">Workflow</a>
            <a href="#why">Why</a>
            <a href="#faq">FAQ</a>
          </nav>
          <div class="header-actions">
            <a class="icon-link" href="https://github.com/omkarbhad/graphini" rel="noreferrer" target="_blank" aria-label="Open GitHub">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.05c-3.34.73-4.04-1.42-4.04-1.42-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.85 1.25 1.85 1.25 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.8 5.62-5.47 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.83.57A12 12 0 0 0 12 .5Z"></path></svg>
            </a>
            <a class="anim-button" href="/app">
              <span class="anim-button-inner">Open app</span>
            </a>
          </div>
        </div>
      </header>

      <main>
        <section class="section hero">
          <div class="container">
            <div class="hero-rule" aria-hidden="true"></div>

            <div class="hero-copy">
              <div class="badge">
                <span class="badge-label">
                  <span class="badge-dot" aria-hidden="true"></span>
                  Cowork for visual thinking
                </span>
              </div>
              <h1 class="hero-text">
                See what
                <mark>you're thinking.</mark>
              </h1>
              <p class="hero-sub">
                Talk an idea through and watch it take shape — diagrams and Markdown that move
                at the speed of thought.
              </p>
            </div>

            <form class="prompt-box" action="/app" method="get">
              <textarea
                class="prompt-box-input"
                name="prompt"
                rows="2"
                placeholder="Describe your diagram…"
                aria-label="Diagram prompt"
                data-prompt-input
              ></textarea>
              <div class="prompt-box-toolbar">
                <div class="prompt-box-tools-left">
                  <button class="prompt-box-secondary" type="button" aria-label="Attach files" disabled>
                    <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
                      <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M12 5v14M5 12h14"/>
                    </svg>
                  </button>
                  <button class="prompt-box-model" type="button" aria-label="Select model" disabled>
                    <span class="prompt-box-model-dot" aria-hidden="true"></span>
                    <span class="prompt-box-model-name">Claude Haiku 4.5</span>
                    <svg viewBox="0 0 24 24" aria-hidden="true" width="12" height="12">
                      <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6"/>
                    </svg>
                  </button>
                </div>
                <div class="prompt-box-tools-right">
                  <button class="prompt-box-submit" type="submit" aria-label="Send prompt">
                    <svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14">
                      <path fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" d="M12 19V5M5 12l7-7 7 7"/>
                    </svg>
                  </button>
                </div>
              </div>
            </form>

            <ul class="prompt-pills" aria-label="Try a prompt" data-prompt-pills>
              {prompts.map((prompt, i) => (
                <li>
                  <a
                    href={encodedPrompt(prompt.text)}
                    data-prompt={prompt.text}
                    aria-current={i === 0 ? 'true' : 'false'}
                  >
                    <svg class="prompt-pill-icon" aria-hidden="true" focusable="false" width="14" height="14">
                      <use href={`#i-${prompt.icon}`} />
                    </svg>
                    <span>{prompt.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="hero-shape" aria-hidden="true">
            <div class="hero-shape-dome"></div>
          </div>
        </section>

        <section class="section product-showcase" aria-label="Graphini in action">
          <div class="container">
            <a class="product-image" href="/app" aria-label="Open Graphini workspace">
              <div class="product-slideshow" role="img" aria-label="Graphini workspace screenshots: ER and sequence diagrams in dark mode">
                <img
                  class="slide"
                  src="/demos/demo-dark-er@1x.webp"
                  srcset="/demos/demo-dark-er@1x.webp 900w, /demos/demo-dark-er@2x.webp 1800w"
                  sizes="(min-width: 1024px) 1100px, 100vw"
                  width="1800"
                  height="906"
                  loading="lazy"
                  decoding="async"
                  alt=""
                />
                <img
                  class="slide"
                  src="/demos/demo-dark-sequence@1x.webp"
                  srcset="/demos/demo-dark-sequence@1x.webp 900w, /demos/demo-dark-sequence@2x.webp 1800w"
                  sizes="(min-width: 1024px) 1100px, 100vw"
                  width="1800"
                  height="906"
                  loading="lazy"
                  decoding="async"
                  alt=""
                />
              </div>
            </a>
          </div>
        </section>

        <section class="section tool-strip" aria-label="Graphini toolchain">
          <div class="container">
            <p class="tool-strip-label">Built around portable diagram workflows</p>
            <div class="tool-strip-pills">
              {integrations.map((item) => <span>{item}</span>)}
            </div>
          </div>
        </section>

        <section id="features" class="section feature-track">
          <div class="container feature-grid">
            <div class="sticky-copy">
              <div class="badge"><span class="badge-label">Key Features</span></div>
              <h2>More structure for the messy middle of technical thinking.</h2>
              <div class="track-list">
                {features.map((feature) => <span>{feature.track}</span>)}
              </div>
            </div>
            <div class="feature-cards">
              {features.map((feature) => (
                <article>
                  <span class="feature-track-label">{feature.track}</span>
                  <h3>{feature.title}</h3>
                  <p>{feature.text}</p>
                  <ul>
                    {feature.points.map((point) => <li>{point}</li>)}
                  </ul>
                  <div class="card-shape" aria-hidden="true">
                    <div class="card-shape-glow card-shape-glow-tr"></div>
                    <div class="card-shape-glow card-shape-glow-bl"></div>
                    <div class="mini-canvas">
                      <div></div><div></div><div></div><div></div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="section stats-section">
          <div class="container stats-grid">
            {stats.map(([value, label]) => (
              <article>
                <strong>{value}</strong>
                <span>{label}</span>
              </article>
            ))}
          </div>
        </section>

        <section class="section essentials-section">
          <div class="container">
            <div class="section-header">
              <div class="badge"><span class="badge-label">Essential Features</span></div>
              <h2>Everything a diagramming workspace owes the engineer using it.</h2>
            </div>
            <div class="essentials-grid">
              {essentials.map((feature, index) => (
                <article class={index <= 1 ? 'essentials-card essentials-card-wide' : 'essentials-card'}>
                  <div class="essentials-halo" aria-hidden="true"></div>
                  <div class="essentials-preview" aria-hidden="true">
                    {feature.title === 'Live canvas preview' && (
                      <svg class="canvas-mock" viewBox="0 0 570 310" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Diagram canvas with three connected nodes">
                        <defs>
                          <pattern id="canvasDots" width="20" height="20" patternUnits="userSpaceOnUse">
                            <circle cx="1" cy="1" r="1" fill="rgba(255,255,255,0.08)"/>
                          </pattern>
                          <radialGradient id="canvasVignette" cx="50%" cy="50%" r="70%">
                            <stop offset="0%" stop-color="rgba(124,58,237,0.05)"/>
                            <stop offset="100%" stop-color="transparent"/>
                          </radialGradient>
                          <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#7c3aed"/>
                          </marker>
                        </defs>
                        <rect width="570" height="310" fill="url(#canvasDots)"/>
                        <rect width="570" height="310" fill="url(#canvasVignette)"/>
                        <path d="M 200 110 C 230 110, 250 155, 280 155" fill="none" stroke="#7c3aed" stroke-width="1.5" marker-end="url(#arrow)" stroke-opacity="0.7"/>
                        <path d="M 400 155 C 430 155, 450 220, 480 220" fill="none" stroke="#7c3aed" stroke-width="1.5" marker-end="url(#arrow)" stroke-opacity="0.7"/>
                        <g>
                          <rect x="60" y="84" width="140" height="52" rx="10" fill="#131313" stroke="#262626"/>
                          <rect x="60" y="84" width="140" height="20" rx="10" fill="rgba(124,58,237,0.06)"/>
                          <rect x="60" y="98" width="140" height="6" fill="rgba(124,58,237,0.06)"/>
                          <circle cx="76" cy="94" r="3" fill="#7c3aed"/>
                          <text x="88" y="98" font-family="'JetBrains Mono', monospace" font-size="9" fill="rgba(228,228,228,0.55)" text-transform="uppercase" letter-spacing="0.5">node</text>
                          <text x="74" y="124" font-family="Inter, sans-serif" font-size="13" font-weight="500" fill="#e4e4e4">User</text>
                        </g>
                        <g>
                          <rect x="240" y="129" width="140" height="52" rx="10" fill="#131313" stroke="#7c3aed" stroke-width="1.5"/>
                          <rect x="240" y="129" width="140" height="20" rx="10" fill="rgba(124,58,237,0.12)"/>
                          <rect x="240" y="143" width="140" height="6" fill="rgba(124,58,237,0.12)"/>
                          <circle cx="256" cy="139" r="3" fill="#3fa266"/>
                          <text x="268" y="143" font-family="'JetBrains Mono', monospace" font-size="9" fill="rgba(228,228,228,0.65)" text-transform="uppercase" letter-spacing="0.5">selected</text>
                          <text x="254" y="169" font-family="Inter, sans-serif" font-size="13" font-weight="500" fill="#e4e4e4">API service</text>
                        </g>
                        <g>
                          <rect x="420" y="194" width="140" height="52" rx="10" fill="#131313" stroke="#262626"/>
                          <rect x="420" y="194" width="140" height="20" rx="10" fill="rgba(124,58,237,0.06)"/>
                          <rect x="420" y="208" width="140" height="6" fill="rgba(124,58,237,0.06)"/>
                          <circle cx="436" cy="204" r="3" fill="#7c3aed"/>
                          <text x="448" y="208" font-family="'JetBrains Mono', monospace" font-size="9" fill="rgba(228,228,228,0.55)" text-transform="uppercase" letter-spacing="0.5">store</text>
                          <text x="434" y="234" font-family="Inter, sans-serif" font-size="13" font-weight="500" fill="#e4e4e4">Database</text>
                        </g>
                        <g>
                          <rect x="220" y="115" width="6" height="6" fill="#7c3aed" stroke="#0a0a0a"/>
                          <rect x="394" y="115" width="6" height="6" fill="#7c3aed" stroke="#0a0a0a"/>
                          <rect x="220" y="171" width="6" height="6" fill="#7c3aed" stroke="#0a0a0a"/>
                          <rect x="394" y="171" width="6" height="6" fill="#7c3aed" stroke="#0a0a0a"/>
                        </g>
                        <g transform="translate(450, 16)">
                          <rect x="0" y="0" width="104" height="28" rx="8" fill="rgba(19,19,19,0.92)" stroke="#262626"/>
                          <text x="13" y="19" font-family="Inter, sans-serif" font-size="14" font-weight="500" fill="#e4e4e4">−</text>
                          <text x="52" y="18" font-family="'JetBrains Mono', monospace" font-size="10" fill="rgba(228,228,228,0.65)" text-anchor="middle">100%</text>
                          <text x="89" y="19" font-family="Inter, sans-serif" font-size="14" font-weight="500" fill="#e4e4e4">+</text>
                          <line x1="28" y1="7" x2="28" y2="21" stroke="#262626"/>
                          <line x1="76" y1="7" x2="76" y2="21" stroke="#262626"/>
                        </g>
                        <g transform="translate(414, 16)">
                          <rect x="0" y="0" width="28" height="28" rx="8" fill="rgba(19,19,19,0.92)" stroke="#262626"/>
                          <path d="M 8 8 L 8 12 M 8 8 L 12 8 M 20 8 L 20 12 M 20 8 L 16 8 M 8 20 L 8 16 M 8 20 L 12 20 M 20 20 L 20 16 M 20 20 L 16 20" stroke="#e4e4e4" stroke-width="1.4" stroke-linecap="round" fill="none"/>
                        </g>
                        <g transform="translate(16, 16)">
                          <rect x="0" y="0" width="68" height="28" rx="8" fill="rgba(19,19,19,0.92)" stroke="#262626"/>
                          <circle cx="14" cy="14" r="3" fill="#3fa266"/>
                          <circle cx="14" cy="14" r="3" fill="#3fa266" opacity="0.4">
                            <animate attributeName="r" values="3;8;3" dur="2.4s" repeatCount="indefinite"/>
                            <animate attributeName="opacity" values="0.4;0;0.4" dur="2.4s" repeatCount="indefinite"/>
                          </circle>
                          <text x="26" y="18" font-family="'JetBrains Mono', monospace" font-size="10" fill="rgba(228,228,228,0.75)" text-transform="uppercase" letter-spacing="0.5">live</text>
                        </g>
                        <g transform="translate(16, 278)">
                          <text x="0" y="11" font-family="'JetBrains Mono', monospace" font-size="10" fill="rgba(228,228,228,0.45)">x: 240  y: 155  zoom: 1.00</text>
                        </g>
                      </svg>
                    )}

                    {feature.title === 'Mermaid-native rendering' && (
                      <svg class="canvas-mock" viewBox="0 0 570 310" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Mermaid source code rendering into a diagram">
                        <defs>
                          <pattern id="mermaidDots" width="20" height="20" patternUnits="userSpaceOnUse">
                            <circle cx="1" cy="1" r="1" fill="rgba(255,255,255,0.06)"/>
                          </pattern>
                        </defs>
                        <rect x="32" y="40" width="240" height="232" rx="12" fill="#0a0a0a" stroke="#262626"/>
                        <rect x="32" y="40" width="240" height="36" fill="#131313"/>
                        <path d="M 32 52 a 12 12 0 0 1 12 -12 L 260 40 a 12 12 0 0 1 12 12 L 272 76 L 32 76 Z" fill="#131313"/>
                        <circle cx="50" cy="58" r="4" fill="#ff6b6b"/>

    border-radius: 6px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease, border-color 150ms ease;
  }

  .prompt-box-secondary:hover:not(:disabled) {
    color: var(--text);
    background: color-mix(in srgb, var(--text) 8%, transparent);
  }

  .prompt-box-secondary:disabled {
    cursor: default;
    opacity: 0.7;
  }

  /* Model picker pill — matches app .composer-model-trigger (h-7 rounded-md) */
  .prompt-box-model {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 28px;
    min-width: 0;
    padding: 0 8px;
    border: 1px solid transparent;
    border-radius: 6px;
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1;
    font-weight: 500;
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease, border-color 150ms ease;
  }

  .prompt-box-model:hover:not(:disabled) {
    color: var(--text);
    background: color-mix(in srgb, var(--text) 8%, transparent);
  }

  .prompt-box-model:disabled {
    cursor: default;
    opacity: 0.7;
  }

  .prompt-box-model-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--gradient-accent);
    flex-shrink: 0;
  }

  .prompt-box-model-name {
    min-width: 0;
    max-width: 160px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Submit — matches app .composer-accent-control size-8 rounded-full */
  .prompt-box-submit {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    border: 1px solid transparent;
    border-radius: 9999px;
    background: var(--gradient-accent);
    color: #fff;
    cursor: pointer;
    transition: filter 150ms ease, box-shadow 150ms ease;
  }

  .prompt-box-submit:hover {
    filter: brightness(1.08);
  }

  .prompt-box-submit:active {
    filter: brightness(0.95);
  }

  /* Suggested prompts — compact pills, one-tap to start a thought.
     Generic enough for anyone (not just engineers). The active pill
     cycles every 4s in sync with the prompt-box placeholder. */
  .prompt-pills {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin: 16px 0 0;
    padding: 0;
    list-style: none;
  }

  .prompt-pills a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 32px;
    padding: 0 14px;
    border: 1px solid var(--border-2);
    border-radius: 9999px;
    background: color-mix(in srgb, var(--card), transparent 40%);
    color: var(--text-light);
    font-size: var(--fs-body);
    line-height: 1;
    font-weight: 500;
    white-space: nowrap;
    transition:
      border-color 250ms ease,
      color 250ms ease,
      background 250ms ease,
      transform 200ms ease;
  }

  .prompt-pill-icon {
    flex-shrink: 0;
    color: currentColor;
    opacity: 0.85;
  }

  .prompt-pills a:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent), transparent 40%);
    background: color-mix(in srgb, var(--accent), transparent 88%);
    transform: translateY(-1px);
  }

  .prompt-pills a:active {
    transform: translateY(0);
  }

  /* Active pill — synced with the cycling placeholder. */
  .prompt-pills a[aria-current="true"] {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent), transparent 30%);
    background: color-mix(in srgb, var(--accent), transparent 82%);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent), transparent 92%);
  }

  .prompt-pills a[aria-current="true"] .prompt-pill-icon {
    opacity: 1;
    color: var(--accent-300);
  }

  @media (prefers-reduced-motion: reduce) {
    .prompt-pills a {
      transition: none;
    }
  }

  .product-image {
    position: relative;
    z-index: 2;
    display: block;
    margin-top: 48px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 40px 120px rgba(66, 0, 203, 0.18);
  }

  /* Slideshow — 2 dark-mode slides with staggered fade cycles.
     Total cycle is 10s (2 slides × 5s each), each visible ~4s with
     ~1s crossfade. Stacks via absolute positioning so the container
     has a fixed aspect from the first child. */
  .product-slideshow {
    position: relative;
    width: 100%;
    aspect-ratio: 2934 / 1544;
    background: var(--card);
  }

  .product-slideshow .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left top;
    opacity: 0;
    animation: slideshowFade 10s infinite;
  }

  /* Stagger each slide by 5s into the 10s cycle. */
  .product-slideshow .slide:nth-child(1) { animation-delay: 0s; }
  .product-slideshow .slide:nth-child(2) { animation-delay: 5s; }

  @keyframes slideshowFade {
    0%   { opacity: 0; }
    10%  { opacity: 1; }
    50%  { opacity: 1; }
    60%  { opacity: 0; }
    100% { opacity: 0; }
  }

  /* Respect reduced motion — show only the first slide statically. */
  @media (prefers-reduced-motion: reduce) {
    .product-slideshow .slide {
      animation: none;
    }
    .product-slideshow .slide:nth-child(1) {
      opacity: 1;
    }
  }

  /* Hero shape — gradient ribbon + dome */
  .hero-shape {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(100%, 1500px);
    height: 700px;
    pointer-events: none;
    z-index: 0;
  }

  .hero-shape-dome {
    position: absolute;
    bottom: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 320px;
    background: radial-gradient(ellipse at center bottom, var(--accent-600) 0%, transparent 70%);
    filter: blur(100px);
    opacity: 0.40;
    border-radius: 50% 50% 0 0;
  }

  /* ===== Tool Strip ===== */
  .tool-strip {
    padding: 48px 0;
  }

  .tool-strip .container {
    display: grid;
    gap: 24px;
    text-align: center;
  }

  .tool-strip-label {
    color: var(--text-muted);
    font-size: var(--fs-eyebrow);
    line-height: var(--lh-eyebrow);
    font-weight: 500;
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
  }

  .tool-strip-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }

  .tool-strip-pills span {
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 9999px;
    background: var(--gradient-dark);
    color: var(--text-muted);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    font-weight: 500;
  }

  /* ===== Feature Track (Key Features) ===== */
  .feature-track {
    padding: 96px 0;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 48px;
  }

  .sticky-copy {
    position: sticky;
    top: 100px;
    align-self: start;
  }

  .sticky-copy h2 {
    margin-top: 16px;
    max-width: 540px;
    font-size: clamp(var(--fs-headline), 2.6vw, var(--fs-display-md));
    line-height: var(--lh-display-md);
    letter-spacing: var(--tr-display-md);
    font-weight: 600;
  }

  .track-list {
    display: grid;
    gap: 12px;
    margin-top: 32px;
  }

  .track-list span {
    color: rgba(255, 255, 255, 0.5);
    font-size: var(--fs-body-lg);
    line-height: var(--lh-body-lg);
    letter-spacing: var(--tr-body-lg);
    transition: color 200ms ease, transform 200ms ease;
  }

  .track-list span:first-child {
    color: var(--accent);
    transform: translateX(8px);
  }

  .feature-cards {
    display: grid;
    gap: 16px;
  }

  .feature-cards article {
    position: relative;
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--card);
    overflow: hidden;
  }

  .feature-track-label {
    display: inline-block;
    color: var(--accent);
    font-weight: 500;
    font-size: var(--fs-eyebrow);
    line-height: var(--lh-eyebrow);
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
  }

  .feature-cards h3 {
    margin-top: 16px;
    max-width: 480px;
    font-size: var(--fs-headline);
    line-height: var(--lh-headline);
    letter-spacing: var(--tr-headline);
    font-weight: 600;
  }

  .feature-cards p {
    max-width: 520px;
    margin-top: 12px;
    color: var(--text-muted);
    font-size: var(--fs-body-lg);
    line-height: var(--lh-body-lg);
    letter-spacing: var(--tr-body-lg);
  }

  .feature-cards ul {
    display: grid;
    gap: 8px;
    margin: 16px 0 0;
    padding-left: 24px;
  }

  .feature-cards ul li {
    color: var(--text-light);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    font-weight: 500;
  }

  .feature-cards ul li::marker {
    color: var(--accent);
  }

  .card-shape {
    position: relative;
    margin-top: 24px;
    border-radius: 16px;
    background: color-mix(in srgb, var(--card), transparent 50%);
    padding: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
  }

  .card-shape-glow {
    position: absolute;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--atmosphere-soft) 0%, transparent 70%);
    filter: blur(60px);
    opacity: 0.18;
    pointer-events: none;
  }

  .card-shape-glow-tr {
    top: -80px;
    right: -60px;
  }

  .card-shape-glow-bl {
    bottom: -90px;
    left: -70px;
  }

  .mini-canvas {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    border-radius: 12px;
    background:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      color-mix(in srgb, var(--card-2), transparent 30%);
    background-size: 24px 24px;
    padding: 16px;
    z-index: 1;
  }

  .mini-canvas div {
    min-height: 72px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: color-mix(in srgb, var(--card), transparent 30%);
  }

  /* ===== Essential Features (PowerAI 6-col asymmetric grid) ===== */
  .essentials-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }

  .essentials-card {
    position: relative;
    grid-column: span 2;
    overflow: hidden;
    padding: 8px;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--gradient-dark);
  }

  .essentials-card-wide {
    grid-column: span 3;
  }

  .essentials-halo {
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 420px;
    height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--atmosphere-soft) 0%, transparent 60%);
    filter: blur(50px);
    opacity: 0.18;
    pointer-events: none;
  }

  .essentials-preview {
    position: relative;
    z-index: 1;
    aspect-ratio: 570 / 310;
    border-radius: 16px;
    border: 1px solid var(--border);
    background:
      radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      var(--card);
    background-size: 20px 20px;
    background-position: 0 0;
    overflow: hidden;
  }

  .essentials-preview-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    padding: 24px;
    height: 100%;
  }

  .essentials-preview-grid > div {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: color-mix(in srgb, var(--card-2), transparent 30%);
  }

  .canvas-mock {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .canvas-mock animate { display: none; }
  }

  .essentials-body {
    position: relative;
    z-index: 1;
    padding: 24px 24px 48px;
  }

  .essentials-body h3 {
    margin-bottom: 16px;
    font-size: var(--fs-card-title);
    line-height: var(--lh-card-title);
    letter-spacing: var(--tr-card-title);
    font-weight: 500;
  }

  .essentials-body p {
    color: var(--text-muted);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }

  /* ===== Stats ===== */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .stats-grid article {
    min-height: 180px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 12px;
    padding: 32px;
    text-align: center;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--gradient-dark);
    position: relative;
    overflow: hidden;
  }

  .stats-grid article::before {
    content: '';
    position: absolute;
    inset: -40% -20% auto auto;
    width: 240px;
    height: 240px;
    background: radial-gradient(circle, var(--atmosphere-soft) 0%, transparent 70%);
    filter: blur(70px);
    opacity: 0.10;
    pointer-events: none;
  }

  .stats-grid strong {
    position: relative;
    font-size: var(--fs-display-lg);
    line-height: var(--lh-display-lg);
    letter-spacing: var(--tr-display-lg);
    font-weight: 600;
    color: var(--text);
  }

  .stats-grid span {
    position: relative;
    color: var(--text-muted);
    font-size: var(--fs-caption);
    line-height: var(--lh-caption);
  }

  /* ===== Section Headers ===== */
  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 640px;
    margin: 0 auto 56px;
  }

  .section-header h2 {
    font-size: clamp(var(--fs-headline), 2.6vw, var(--fs-display-md));
    line-height: var(--lh-display-md);
    letter-spacing: var(--tr-display-md);
    font-weight: 600;
  }

  /* ===== Workflow ===== */
  .workflow-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .workflow-grid article {
    position: relative;
    min-height: 220px;
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--gradient-dark);
    overflow: hidden;
  }

  .workflow-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--card);
    display: grid;
    place-items: center;
    margin-bottom: 24px;
  }

  .workflow-icon span {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    line-height: var(--lh-mono);
    font-weight: 500;
  }

  .workflow-grid h3 {
    font-size: var(--fs-card-title);
    line-height: var(--lh-card-title);
    letter-spacing: var(--tr-card-title);
    font-weight: 500;
  }

  .workflow-grid p {
    margin-top: 8px;
    color: var(--text-muted);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }

  /* ===== Why ===== */
  .why-section .container {
    position: relative;
  }

  .why-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .why-grid article {
    padding: 32px;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .why-grid article:nth-child(3n) {
    border-right: 0;
  }

  .why-grid article:nth-last-child(-n+3):not(.why-star) {
    border-bottom: 0;
  }

  .icon-box {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--gradient-dark);
    display: grid;
    place-items: center;
    margin-bottom: 24px;
    color: var(--accent);
  }

  .icon-box svg {
    width: 26px;
    height: 26px;
  }

  .why-grid article h3 {
    font-size: var(--fs-card-title);
    line-height: var(--lh-card-title);
    letter-spacing: var(--tr-card-title);
    font-weight: 500;
  }

  .why-grid article p {
    margin-top: 8px;
    color: var(--text-muted);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }

  /* 8-point star markers at grid intersections (CSS-only) */
  .why-star {
    position: absolute;
    width: 18px;
    height: 18px;
    background: var(--body);
    border: 1px solid var(--border-2);
    transform: rotate(45deg);
    z-index: 2;
    pointer-events: none;
  }

  .why-star::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--body);
    border: 1px solid var(--border-2);
    transform: rotate(45deg);
  }

  .why-star-1 { top: calc(33.333% - 9px); left: calc(33.333% - 9px); }
  .why-star-2 { top: calc(33.333% - 9px); left: calc(66.666% - 9px); }
  .why-star-3 { top: calc(66.666% - 9px); left: calc(33.333% - 9px); }
  .why-star-4 { top: calc(66.666% - 9px); left: calc(66.666% - 9px); }

  /* ===== Integration ===== */
  .integration-card {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    align-items: center;
    gap: 48px;
    padding: 48px;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--gradient-dark);
    box-shadow: 0 24px 48px -16px rgba(0, 0, 0, 0.4);
    position: relative;
    overflow: hidden;
  }

  .integration-card::before {
    content: '';
    position: absolute;
    inset: auto -10% -50% auto;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--atmosphere-soft) 0%, transparent 70%);
    filter: blur(110px);
    opacity: 0.10;
    pointer-events: none;
  }

  .integration-card h2 {
    margin-top: 16px;
    font-size: clamp(var(--fs-card-title), 2.2vw, var(--fs-headline));
    line-height: var(--lh-headline);
    letter-spacing: var(--tr-headline);
    font-weight: 600;
  }

  .integration-cloud {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .integration-cloud span {
    padding: 8px 16px;
    border: 1px solid var(--border-2);
    border-radius: 9999px;
    background: color-mix(in srgb, var(--card), transparent 30%);
    color: var(--text-light);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    font-weight: 500;
    transition: border-color 200ms ease, transform 200ms ease;
  }

  .integration-cloud span:hover {
    border-color: color-mix(in srgb, var(--accent), transparent 50%);
    transform: translateY(-2px);
  }

  /* ===== FAQ ===== */
  .faq-section .section-header {
    margin-bottom: 48px;
  }

  .faq-list {
    max-width: 820px;
    margin: 0 auto;
    display: grid;
    gap: 12px;
  }

  .faq-list details {
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--card);
    padding: 16px 24px;
    transition: border-color 200ms ease, background 200ms ease;
  }

  .faq-list details[open] {
    border-color: var(--border-2);
    background: var(--card-2);
  }

  .faq-list summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    cursor: pointer;
    list-style: none;
    color: var(--text);
    font-weight: 500;
    font-size: var(--fs-card-title);
    line-height: var(--lh-card-title);
    letter-spacing: var(--tr-card-title);
  }

  .faq-list summary::-webkit-details-marker {
    display: none;
  }

  .faq-list summary i {
    flex: 0 0 auto;
    width: 24px;
    height: 24px;
    border-radius: 9999px;
    background: var(--gradient-accent);
    position: relative;
    transition: transform 200ms ease;
  }

  .faq-list summary i::before,
  .faq-list summary i::after {
    content: '';
    position: absolute;
    background: white;
    border-radius: 1px;
  }

  .faq-list summary i::before {
    inset: calc(50% - 1px) 6px;
    height: 2px;
  }

  .faq-list summary i::after {
    inset: 6px calc(50% - 1px);
    width: 2px;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  .faq-list details[open] summary i::after {
    transform: scaleY(0);
    opacity: 0;
  }

  .faq-list p {
    margin-top: 12px;
    color: var(--text-muted);
    font-size: var(--fs-body-lg);
    line-height: var(--lh-body-lg);
    letter-spacing: var(--tr-body-lg);
  }

  /* ===== CTA ===== */
  .cta-section {
    position: relative;
    padding: 96px 0;
    overflow: hidden;
    text-align: center;
  }

  .cta-section > .container {
    border-left: 0;
    border-right: 0;
  }

  .cta-content {
    position: relative;
    z-index: 3;
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-content h2 {
    font-size: clamp(var(--fs-headline), 3vw, var(--fs-display-md));
    line-height: var(--lh-display-md);

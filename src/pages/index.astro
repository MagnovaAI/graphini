    --border-2: rgba(228, 228, 228, 0.10);
    --border-3: rgba(228, 228, 228, 0.20);
    /* ===== Accent tonal scale =====
       Derived from brand hue 264° (sampled from static/brand/logo.png).
       Constant hue, descending lightness — one hue, 9 predictable stops.
       Use --accent-500 as the default solid accent; the others for hover,
       active, disabled, soft fills, deep shadows, etc. */
    --accent-50:  #f4ecff;  /* near-white tint — backgrounds, soft fills */
    --accent-100: #e7d4ff;
    --accent-200: #cea8ff;
    --accent-300: #b07eff;
    --accent-400: #9659f6;
    --accent-500: #7c3aed;  /* default solid accent */
    --accent-600: #6300ee;  /* brand violet */
    --accent-700: #4f00c7;
    --accent-800: #3700ad;
    --accent-900: #2000a7;  /* brand indigo */

    /* Semantic aliases — call sites should prefer these. */
    --primary:    var(--accent-900);
    --secondary:  var(--accent-600);
    --accent:     var(--accent-500);
    --accent-soft: rgba(124, 58, 237, 0.12);

    /* Single accent gradient — used for buttons, gradient text fills, decorative accents. */
    --gradient-accent: linear-gradient(135deg, var(--accent-900) 0%, var(--accent-600) 100%);
    --gradient-dark: linear-gradient(180deg, #0d0d0d 0%, #161616 100%);
    --gradient-text-hero: linear-gradient(270deg, #fff 2.46%, var(--accent-600) 50.39%, #fff 98.32%);
    /* Soft atmosphere — logo midpoint hue for decorative glows. */
    --atmosphere: radial-gradient(circle, var(--accent-600) 0%, var(--accent-900) 70%);
    --atmosphere-soft: var(--accent-700);
    --success: #3fa266;

    /* Composer (matches app chat input surface, --chat-input-bg in app.css). */
    --chat-input-bg: #1c1c1c;

    /* Type scale tokens (--fs-*, --lh-*, --tr-*) live in src/app.css */
    --font-sans: 'Inter', 'SF Pro Display', -apple-system, system-ui, 'Segoe UI', Roboto, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: #0a0a0a;
    color: var(--text-light);
    font-family: var(--font-sans);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    letter-spacing: var(--tr-body);
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1, h2, h3, h4, h5, h6, p {
    margin: 0;
  }

  h1, h2, h3, h4, h5, h6 {
    color: var(--text);
    font-weight: 600;
    line-height: 1.2;
    scroll-margin-top: 96px;
  }

  /* Default heading sizes from the DESIGN.md ladder; specific sections override below. */
  h1 { font-size: var(--fs-display-lg); line-height: var(--lh-display-lg); letter-spacing: var(--tr-display-lg); font-weight: 600; }
  h2 { font-size: var(--fs-display-md); line-height: var(--lh-display-md); letter-spacing: var(--tr-display-md); font-weight: 600; }
  h3 { font-size: var(--fs-headline);   line-height: var(--lh-headline);   letter-spacing: var(--tr-headline);   font-weight: 600; }

    <!-- Prompt pill + placeholder cycler. Stops the moment the user
         focuses the textarea so we never overwrite their input. -->
    <script is:inline>
      (function () {
        var pills = document.querySelectorAll('[data-prompt-pills] a[data-prompt]');
        var input = document.querySelector('[data-prompt-input]');
        if (!pills.length || !input) return;

        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reducedMotion) {
          input.setAttribute('placeholder', pills[0].getAttribute('data-prompt'));
          return;
        }

        var i = 0;
        var stopped = false;
        var timer;

        function applyActive(idx) {
          for (var j = 0; j < pills.length; j++) {
            pills[j].setAttribute('aria-current', j === idx ? 'true' : 'false');
          }
          input.setAttribute('placeholder', pills[idx].getAttribute('data-prompt'));
        }

        function tick() {
          if (stopped) return;
          i = (i + 1) % pills.length;
          applyActive(i);
          timer = setTimeout(tick, 4500);
        }

        function stop() {
          stopped = true;
          if (timer) clearTimeout(timer);
          input.setAttribute('placeholder', 'Describe your diagram…');
        }

        // Initial state.
        applyActive(0);
        timer = setTimeout(tick, 4500);

        // User intent stops the cycler.
        input.addEventListener('focus', stop, { once: true });
        input.addEventListener('input', stop, { once: true });

        // Tapping a pill stops the cycler too — they've made their choice.
        for (var k = 0; k < pills.length; k++) {
          pills[k].addEventListener('click', function () {
            stopped = true;
            if (timer) clearTimeout(timer);
          });
          // Hovering a pill pauses the cycle so the user can read it.
          pills[k].addEventListener('mouseenter', function () {
            if (timer) clearTimeout(timer);
          });
          pills[k].addEventListener('mouseleave', function () {
            if (!stopped) timer = setTimeout(tick, 1500);
          });
        }
      })();
    </script>

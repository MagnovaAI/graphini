    color: var(--text);
    border-color: var(--border-2);
  }

  .icon-link svg {
    width: 16px;
    height: 16px;
  }

  /* ===== Animated Button ===== */
  .anim-button {
    display: inline-block;
    padding: 4px;
    border: 1px solid var(--border-3);
    border-radius: 9999px;
    transition: padding 200ms ease, border-color 200ms ease;
    line-height: 1;
  }

  .anim-button:hover {
    padding: 0;
    border-color: var(--border-3);
  }

  .anim-button-inner {
    display: inline-block;
    padding: 12px 24px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.20);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    color: var(--text);
    font-size: var(--fs-button);
    line-height: var(--lh-button);
    font-weight: 500;
    transition: padding 200ms ease, background 200ms ease, border-color 200ms ease;
  }

  .anim-button:hover .anim-button-inner {
    padding: 16px 32px;
  }

  .anim-button:not(.anim-button-primary):hover .anim-button-inner {
    background: rgba(255, 255, 255, 0.10);
    border-color: rgba(255, 255, 255, 0.30);
  }

  .anim-button-primary .anim-button-inner {
    background: var(--gradient-accent);
    border-color: var(--primary);
  }

  .anim-button-primary:hover .anim-button-inner {
    filter: brightness(1.08);
  }

  /* ===== Badge — gradient ring, dark inner pill, eyebrow label =====
     Markup: <div class="badge"><span class="badge-label">[<span class="badge-dot">] text</span></div>
     The dot lives inside the label so flex-gap handles spacing. */
  .badge {
    display: inline-flex;
    background: var(--gradient-accent);
    padding: 1px;
    border-radius: 9999px;
  }

  .badge-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 9999px;
    background: var(--gradient-dark);
    color: var(--text);
    font-size: var(--fs-eyebrow);
    line-height: var(--lh-eyebrow);
    letter-spacing: var(--tr-eyebrow);
    font-weight: 600;
    text-transform: uppercase;
  }

  /* When a dot is present, push the row inward so the halo clears the pill's
     rounded edge. Pill height ~32px → border-radius effective ≈16px on the
     left curve, so 24px left padding keeps the 4px halo fully inside. */
  .badge-label:has(.badge-dot) {
    padding-left: 24px;
  }

  .badge-dot {
    flex: 0 0 auto;
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--success);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--success), transparent 70%);
  }


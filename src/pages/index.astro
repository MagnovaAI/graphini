     hero content vertically centers inside what's visible after the sticky
     header. min-height not height so tall content doesn't get clipped. */
  .hero {
    min-height: calc(100dvh - var(--header-height, 64px));
    padding: 48px 0;
    display: flex;
    align-items: center;
    overflow: hidden;
